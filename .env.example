# ===========================================
# Morning Signal V2 — Environment Variables
# ===========================================

# OpenAI Configuration
OPENAI_API_KEY=sk-your-openai-api-key-here

# Parallel AI Search API
PARALLEL_AI_API_KEY=your-parallel-ai-api-key-here

# SendGrid Email Delivery
SENDGRID_API_KEY=SG.your-sendgrid-api-key-here
SENDGRID_FROM_EMAIL=newsletter@yourdomain.com
SENDGRID_FROM_NAME=The Morning Signal

# PostgreSQL Database
DATABASE_URL=postgresql://user:password@host:5432/morning_signal_v2
# Or individual connection params:
DB_HOST=localhost
DB_PORT=5432
DB_NAME=morning_signal_v2
DB_USER=postgres
DB_PASSWORD=your-password-here
DB_SSL=false

# LLM Model Configuration (configurable — not hardcoded)
LLM_MODEL_RESEARCHER=gpt-4o-mini
LLM_MODEL_WRITER_LEAD=gpt-4o
LLM_MODEL_WRITER_BRIEFINGS=gpt-4o-mini
LLM_MODEL_SUBJECT_LINE=gpt-4o-mini

# Application
NODE_ENV=development
PORT=3000

# Cost Budget
COST_BUDGET_PER_EDITION=1.00

# Newsletter
NEWSLETTER_NAME=The Morning Signal
UNSUBSCRIBE_URL=https://yourdomain.com/unsubscribe
PHYSICAL_ADDRESS=123 Main St, Washington, DC 20001
