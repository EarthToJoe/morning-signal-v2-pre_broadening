{
  "name": "morning-signal-v2",
  "version": "2.0.0",
  "description": "The Morning Signal V2 — Automated newsletter for defense, energy, and technology professionals",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "ts-node src/index.ts",
    "test": "jest --runInBand",
    "test:unit": "jest --runInBand --testPathPattern=__tests__/unit",
    "test:property": "jest --runInBand --testPathPattern=__tests__/property",
    "test:integration": "jest --runInBand --testPathPattern=__tests__/integration",
    "lint": "eslint src/ --ext .ts",
    "db:init": "ts-node src/scripts/db-init.ts",
    "db:migrate": "ts-node src/scripts/db-migrate.ts",
    "db:seed": "ts-node src/scripts/db-seed.ts"
  },
  "dependencies": {
    "express": "^4.18.2",
    "pg": "^8.12.0",
    "winston": "^3.11.0",
    "mjml": "^4.15.3",
    "uuid": "^9.0.1",
    "dotenv": "^16.3.1",
    "openai": "^4.52.0",
    "@sendgrid/mail": "^8.1.0",
    "cheerio": "^1.0.0-rc.12",
    "handlebars": "^4.7.8",
    "html-to-text": "^9.0.5"
  },
  "devDependencies": {
    "typescript": "^5.3.3",
    "@types/express": "^4.17.21",
    "@types/pg": "^8.10.9",
    "@types/uuid": "^9.0.7",
    "@types/mjml": "^4.7.4",
    "@types/node": "^20.10.0",
    "@types/html-to-text": "^9.0.4",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.1",
    "@types/jest": "^29.5.7",
    "fast-check": "^3.15.0",
    "eslint": "^8.55.0",
    "@typescript-eslint/eslint-plugin": "^6.13.0",
    "@typescript-eslint/parser": "^6.13.0",
    "ts-node": "^10.9.2"
  }
}
